{
    "application": {
        "name": "PrintServer",
        "version": "1.0.0"
    },

    "web": {
        "host": "0.0.0.0",
        "port": 3000,
        "trustProxy": false,
        "public": "/opt/share/PrintServer/web/public",

        "cors": {
            "enabled": true,
            "origin": "*",
            "credentials": true
        },

        "body": {
            "jsonLimit": "10mb",
            "urlencodedExtended": true
        }
    },

    "socket": {
        "path": "/socket.io",

        "cors": {
            "origin": "*"
        }
    },

    "security": {

        "helmet": true,

        "compression": true,

        "apiKey": {

            "enabled": false,

            "header": "x-api-key",

            "key": "development-key"

        },

        "rateLimit": {

            "enabled": true,

            "windowMs": 60000,

            "max": 300

        }

    },

    "database": {

        "dialect": "mysql",

        "host": "141.13.14.112",

        "port": 3306,

        "database": "drucker",

        "username": "asd",

        "password": "asd",

        "logging": false,

        "timezone": "+01:00",

        "sync": false,

        "alter": false,

        "pool": {

            "max": 10,

            "min": 0,

            "acquire": 30000,

            "idle": 10000

        }

    },

    "drivers": {

        "path": "/opt/share/PrintServer/core/drivers",

        "drivers": [

            "IppDriver"

        ]

    },

    "discovery": {

        "enabled": true,

        "interval": 60000,

        "providers": [

            "StaticProvider",

            "MdnsProvider",

            "IppScanProvider"

        ]

    },

    "monitor": {

        "enabled": true,

        "interval": 30000

    },

    "scheduler": {

        "enabled": true,

        "interval": 1000,

        "parallelJobs": 5

    },

    "logging": {

        "level": "info"

    }

}