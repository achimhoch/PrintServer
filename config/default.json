{
    "application": {

        "name": "Node Print Server", 

        "version": "2.0.0",

        "environment": "development"

    },

    "server": {

        "host": "0.0.0.0",

        "port": 3000,

        "trustProxy": false,

        "cors": {

            "enabled": true,

            "origin": "*"

        },

        "public": "/opt/share/PrintServer/web/public",

         "body": {
            "jsonLimit": "10mb",
            "urlencodedExtended": true
        }

    },

    "socket": {

        "path": "/socket.io",

        "pingTimeout": 20000,

        "pingInterval": 25000,

        "cors": {

            "origin": "*"

        }

    },

    "database": {

        "dialect": "mysql",

        "host": "141.13.14.112",

        "port": 3306,

        "database": "prinserv",

        "username": "asd",

        "password": "asd",

        "logging": false,

        "timezone": "+01:00",

        "sync": false,

        "alter": false,

        "pool": {

            "max": 10,

            "min": 0,

            "idle": 10000,

            "acquire": 30000

        }

    },

    "security": {

        "apiKey": {

            "enabled": false,

            "key": "CHANGE_ME"

        },

        "rateLimit": {

            "enabled": true,

            "windowMs": 60000,

            "max": 300

        }

    },

    "drivers": {

        "ipp": {

            "enabled": true,

            "timeout": 10000,

            "retries": 3

        },

        "raw9100": {

            "enabled": true,

            "port": 9100,

            "timeout": 5000

        },

        "cups": {

            "enabled": false,

            "host": "localhost",

            "port": 631

        },

        "windows": {

            "enabled": false

        },

        "pdf": {

            "enabled": true

        }

    },

    "discovery": {

        "enabled": true,

        "interval": 30000,

        "mdns": {

            "enabled": true,

            "service": "_ipp._tcp.local" 

        },

        "ipp": {

            "enabled": true,

            "timeout": 1500,

            "concurrency": 64,

            "subnets": [

                "141.13.14.0"

            ]

        },

        "static": {

            "enabled": false,

            "printers": [

            ]

        }

    },

    "monitor": {

        "enabled": true,

        "interval": 10000

    },

    "scheduler": {

        "enabled": true,

        "interval": 1000,

        "parallelJobs": 4,

        "retryCount": 3

    },

    "upload": {

        "directory": "./uploads",

        "maxFileSize": "100mb"

    },

    "logging": {

        "level": "info"

    },

    "api": {
    "prefix": "/api",
    "version": "v1"
    },

    "statistics": {
        "enabled": true,
        "history": 1000
    },

    "cache": {
        "enabled": true,
        "ttl": 300
    },

    "queue": {
        "defaultPriority": 5,
        "maxJobs": 10000
    }

}