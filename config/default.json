{
  "server": {
    "name": "Node.js Print Server",
    "version": "1.0.0",
    "environment": "development"
  },

  "http": {
    "host": "0.0.0.0",
    "port": 3000,
    "trustProxy": false
  },

  "websocket": {
    "path": "/socket.io",
    "cors": {
      "origin": "*",
      "methods": [
        "GET",
        "POST"
      ]
    },
    "transports": [
      "websocket",
      "polling"
    ]
  },

  "discovery": {
    "enabled": true,
    "interval": 60000,

    "providers": {
      "mdns": true,
      "ipp": true,
      "snmp": true,
      "static": true
    },

    "networks": [
      "192.168.1.0/24",
      "192.168.2.0/24"
    ],

    "snmp": {
      "community": "public",
      "version": "2c",
      "timeout": 2000
    }
  },

  "monitor": {
    "enabled": true,
    "interval": 15000
  },

  "scheduler": {
    "enabled": true,
    "maxParallelJobs": 10,
    "retryCount": 3,
    "retryDelay": 5000
  },

  "drivers": {
    "default": "ipp",
    "timeout": 30000
  },

  "database": {
    "type": "sqlite",
    "filename": "./database/printserver.db"
  },

  "logging": {
    "level": "info",
    "directory": "./logs",
    "console": true,
    "file": true
  },

  "api": {
    "prefix": "/api",
    "authentication": false
  },

  "dashboard": {
    "title": "Node.js Print Server",
    "theme": "bootstrap",
    "refreshInterval": 5000
  },

  "plugins": {
    "directory": "./plugins",
    "autoload": true
  }
}